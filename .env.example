# AI Role Division API - Environment Variables
# Copy this file to .env and fill in your API keys

# Server
PORT=3000

# Supabase Database (PostgreSQL via connection pooler)
# Transaction mode (port 6543) — used at runtime by Prisma
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection (port 5432) — used for prisma migrate
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# AI Provider API Keys (required for actual AI execution)
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_API_KEY=AIzaxxxxx
PERPLEXITY_API_KEY=pplx-xxxxx
XAI_API_KEY=xai-xxxxx
DEEPSEEK_API_KEY=sk-xxxxx

# Division API Key (for MCP servers, curl, programmatic access)
# Generate a key with ak_ prefix, e.g. ak_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DIVISION_API_KEY=ak_xxxxx

# Clerk Authentication (optional — for frontend OAuth users)
# When omitted, only Division API key auth is available
CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx

# Supabase Authentication (optional — for Supabase-based frontend)
# Allows Supabase JWTs to be used in place of Clerk tokens
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Division API URL (for MCP server & external clients)
DIVISION_API_URL=https://api.division.he-ro.jp

# Credit System (webhook to division.he-ro.jp)
# Shared secret for authenticating credit API calls
DIVISION_WEBHOOK_SECRET=your_webhook_secret_here
# Base URL for the credit API (division-hp frontend)
CREDIT_API_URL=https://division.he-ro.jp

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
