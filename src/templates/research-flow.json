{
  "name": "Research & Analysis Flow",
  "description": "A flow that plans research, gathers information, and synthesizes findings",
  "nodes": [
    {
      "id": "planner",
      "type": "prompt",
      "name": "Research Planner",
      "description": "Creates a research plan based on the query",
      "inputs": [
        {
          "name": "query",
          "type": "string",
          "description": "The research question",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "plan",
          "type": "object",
          "description": "Research plan with key topics"
        }
      ],
      "config": {
        "providerId": "openai",
        "modelId": "gpt-4",
        "temperature": 0.3,
        "maxTokens": 1500
      },
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "researcher",
      "type": "function",
      "name": "Information Gatherer",
      "description": "Gathers information based on the plan",
      "inputs": [
        {
          "name": "plan",
          "type": "object",
          "description": "Research plan",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "findings",
          "type": "array",
          "description": "Gathered research findings"
        }
      ],
      "config": {},
      "position": { "x": 300, "y": 100 }
    },
    {
      "id": "synthesizer",
      "type": "prompt",
      "name": "Findings Synthesizer",
      "description": "Synthesizes findings into coherent summary",
      "inputs": [
        {
          "name": "findings",
          "type": "array",
          "description": "Research findings",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "summary",
          "type": "string",
          "description": "Synthesized summary"
        }
      ],
      "config": {
        "providerId": "openai",
        "modelId": "gpt-4",
        "temperature": 0.5,
        "maxTokens": 3000
      },
      "position": { "x": 500, "y": 100 }
    },
    {
      "id": "output",
      "type": "output",
      "name": "Research Report",
      "description": "Final research report",
      "inputs": [
        {
          "name": "summary",
          "type": "string",
          "description": "Final summary",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "report",
          "type": "string",
          "description": "Complete research report"
        }
      ],
      "config": {},
      "position": { "x": 700, "y": 100 }
    }
  ],
  "edges": [
    {
      "id": "planner-researcher",
      "source": "planner",
      "target": "researcher",
      "sourceHandle": "plan",
      "targetHandle": "plan"
    },
    {
      "id": "researcher-synthesizer",
      "source": "researcher",
      "target": "synthesizer",
      "sourceHandle": "findings",
      "targetHandle": "findings"
    },
    {
      "id": "synthesizer-output",
      "source": "synthesizer",
      "target": "output",
      "sourceHandle": "summary",
      "targetHandle": "summary"
    }
  ],
  "config": {
    "timeout": 120000,
    "retryPolicy": {
      "maxRetries": 3,
      "backoffMs": 2000
    }
  }
}
