{
  "name": "Multi-Agent Collaboration Flow",
  "description": "A flow where multiple AI agents work together to solve complex problems",
  "nodes": [
    {
      "id": "orchestrator",
      "type": "prompt",
      "name": "Task Orchestrator",
      "description": "Breaks down the task and assigns subtasks",
      "inputs": [
        {
          "name": "task",
          "type": "string",
          "description": "The main task to solve",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "subtasks",
          "type": "array",
          "description": "Breakdown of subtasks"
        }
      ],
      "config": {
        "providerId": "openai",
        "modelId": "gpt-4",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "position": { "x": 100, "y": 100 }
    },
    {
      "id": "analyst",
      "type": "prompt",
      "name": "Data Analyst Agent",
      "description": "Analyzes and interprets data",
      "inputs": [
        {
          "name": "subtasks",
          "type": "array",
          "description": "Subtasks for analysis",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "analysis",
          "type": "object",
          "description": "Analysis results"
        }
      ],
      "config": {
        "providerId": "openai",
        "modelId": "gpt-4",
        "temperature": 0.4,
        "maxTokens": 2500
      },
      "position": { "x": 300, "y": 50 }
    },
    {
      "id": "writer",
      "type": "prompt",
      "name": "Content Writer Agent",
      "description": "Creates structured content from analysis",
      "inputs": [
        {
          "name": "subtasks",
          "type": "array",
          "description": "Subtasks for content creation",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "content",
          "type": "string",
          "description": "Generated content"
        }
      ],
      "config": {
        "providerId": "openai",
        "modelId": "gpt-4",
        "temperature": 0.7,
        "maxTokens": 3000
      },
      "position": { "x": 300, "y": 200 }
    },
    {
      "id": "reviewer",
      "type": "prompt",
      "name": "Quality Reviewer",
      "description": "Reviews and integrates outputs from all agents",
      "inputs": [
        {
          "name": "analysis",
          "type": "object",
          "description": "Analysis from analyst",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "Content from writer",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "final_output",
          "type": "object",
          "description": "Final integrated output"
        }
      ],
      "config": {
        "providerId": "openai",
        "modelId": "gpt-4",
        "temperature": 0.2,
        "maxTokens": 2000
      },
      "position": { "x": 500, "y": 125 }
    },
    {
      "id": "output",
      "type": "output",
      "name": "Final Report",
      "description": "Complete solved task",
      "inputs": [
        {
          "name": "final_output",
          "type": "object",
          "description": "Final output",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "report",
          "type": "object",
          "description": "Complete report"
        }
      ],
      "config": {},
      "position": { "x": 700, "y": 125 }
    }
  ],
  "edges": [
    {
      "id": "orchestrator-analyst",
      "source": "orchestrator",
      "target": "analyst",
      "sourceHandle": "subtasks",
      "targetHandle": "subtasks"
    },
    {
      "id": "orchestrator-writer",
      "source": "orchestrator",
      "target": "writer",
      "sourceHandle": "subtasks",
      "targetHandle": "subtasks"
    },
    {
      "id": "analyst-reviewer",
      "source": "analyst",
      "target": "reviewer",
      "sourceHandle": "analysis",
      "targetHandle": "analysis"
    },
    {
      "id": "writer-reviewer",
      "source": "writer",
      "target": "reviewer",
      "sourceHandle": "content",
      "targetHandle": "content"
    },
    {
      "id": "reviewer-output",
      "source": "reviewer",
      "target": "output",
      "sourceHandle": "final_output",
      "targetHandle": "final_output"
    }
  ],
  "config": {
    "timeout": 180000,
    "retryPolicy": {
      "maxRetries": 3,
      "backoffMs": 2000
    }
  }
}
