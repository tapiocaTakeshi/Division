{
    "version": 2,
    "functions": {
        "api/**/*.ts": {
            "maxDuration": 300
        }
    },
    "rewrites": [
        {
            "source": "/api/cron/sync-models",
            "destination": "/api/cron/sync-models"
        },
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/sync-models",
            "schedule": "0 4 * * *"
        }
    ]
}